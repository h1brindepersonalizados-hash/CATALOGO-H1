rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'code', 'category', 'image', 'tiers'])
        && data.id is string
        && data.name is string && data.name.size() <= 200
        && data.code is string
        && data.category is string
        && data.image is string
        && data.tiers is list;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['logo', 'phone', 'adminPassword', 'categories', 'banners', 'themeColor', 'menuIcon'])
        && data.logo is string
        && data.phone is string
        && data.adminPassword is string
        && data.categories is list
        && data.banners is list
        && data.themeColor is string
        && data.menuIcon in ['diamond', 'bag', 'custom'];
    }

    // Products collection
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if true; // Temporary for migration, will harden
    }

    // Settings collection
    match /settings/{configId} {
      allow read: if true;
      allow write: if true; // Temporary for migration, will harden
    }
  }
}
